#!/usr/bin/env bash
# ============================================================
# pre-push-review — Git Pre-Push Hook
# ============================================================
# 在 git push 之前自动运行安全和隐私审查。
# 安装: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# 环境变量:
#   REVIEW_MODE=strict   — 有 HIGH 就阻止 (默认: 仅 CRITICAL 阻止)
#   REVIEW_MODE=warn     — 永远不阻止，仅警告
#   SKIP_REVIEW=1        — 跳过审查 (紧急情况使用)
# ============================================================

set -euo pipefail

# --- 确定脚本所在目录 (兼容被复制到 .git/hooks/ 的情况) ---
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# --- 加载共享库 ---
# 优先从同目录加载 (被复制到 .git/hooks/ 后)
# 其次从相对路径加载 (源代码树中)
if [[ -f "$SCRIPT_DIR/../lib/patterns.sh" ]]; then
  source "$SCRIPT_DIR/../lib/patterns.sh"
elif [[ -f "$SCRIPT_DIR/lib/patterns.sh" ]]; then
  source "$SCRIPT_DIR/lib/patterns.sh"
elif [[ -f "$SCRIPT_DIR/../../code_check/lib/patterns.sh" ]]; then
  source "$SCRIPT_DIR/../../code_check/lib/patterns.sh"
fi

if [[ -f "$SCRIPT_DIR/../lib/config.sh" ]]; then
  source "$SCRIPT_DIR/../lib/config.sh"
elif [[ -f "$SCRIPT_DIR/lib/config.sh" ]]; then
  source "$SCRIPT_DIR/lib/config.sh"
elif [[ -f "$SCRIPT_DIR/../../code_check/lib/config.sh" ]]; then
  source "$SCRIPT_DIR/../../code_check/lib/config.sh"
fi

# --- 加载项目级配置 ---
load_project_config 2>/dev/null || true

# --- 也支持环境变量覆盖 ---
REVIEW_MODE="${REVIEW_MODE:-${CC_REVIEW_MODE:-normal}}"  # normal | strict | warn
SKIP_REVIEW="${SKIP_REVIEW:-${CC_SKIP_REVIEW:-0}}"

# ============================================================
# 初始化
# ============================================================

# --- 跳过审查 ---
if [[ "${SKIP_REVIEW}" == "1" ]]; then
  echo -e "${YELLOW}⚠️  SKIP_REVIEW=1 — 跳过推送前审查${NC}"
  exit 0
fi

echo -e "${BLUE}🔍 pre-push-review — 正在审查即将推送的改动...${NC}"
echo ""

# --- 状态追踪 ---
FAILED=0
WARNINGS=0

# --- 获取远程信息 ---
REMOTE="${1:-origin}"
URL="${2:-}"

# ============================================================
# 主审查逻辑 (逐 ref 处理)
# ============================================================

while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  # --- 确定 diff 范围 ---
  if [[ "$REMOTE_SHA" == "0000000000000000000000000000000000000000" ]]; then
    # 新分支 — 找到 merge base (不能只用 git diff HEAD，push 时工作区通常为空)
    BASE=$(git merge-base origin/main HEAD 2>/dev/null \
      || git merge-base origin/master HEAD 2>/dev/null \
      || git rev-list --max-parents=0 HEAD 2>/dev/null \
      || echo "")
    if [[ -n "$BASE" ]]; then
      RANGE="${BASE}..${LOCAL_SHA}"
      echo "→ 新分支，审查范围: ${RANGE}"
    else
      echo "→ 新分支，无法确定 base，审查所有 commits"
      RANGE=""
    fi
  else
    RANGE="${REMOTE_SHA}..${LOCAL_SHA}"
    echo "→ 审查范围: ${RANGE}"
  fi

  # --- 获取改动文件列表 ---
  if [[ -n "$RANGE" ]]; then
    DIFF_FILES=$(git diff --name-only "${RANGE}" 2>/dev/null || echo "")
  else
    DIFF_FILES=$(git diff --name-only HEAD 2>/dev/null || echo "")
  fi

  if [[ -z "$DIFF_FILES" ]]; then
    echo "  无改动文件，跳过。"
    continue
  fi

  # 过滤忽略路径
  if command -v should_ignore_path &>/dev/null; then
    FILTERED_FILES=""
    while IFS= read -r f; do
      if ! should_ignore_path "$f"; then
        FILTERED_FILES="${FILTERED_FILES}${f}"$'\n'
      fi
    done <<< "$DIFF_FILES"
    DIFF_FILES=$(echo "$FILTERED_FILES" | sed '/^$/d')
  fi

  echo "  改动文件:"
  echo "$DIFF_FILES" | sed 's/^/    /'

  # --- 获取完整 diff ---
  if [[ -n "$RANGE" ]]; then
    DIFF=$(git diff "${RANGE}" 2>/dev/null || echo "")
  else
    DIFF=$(git diff HEAD 2>/dev/null || echo "")
  fi

  # --- 获取仅包含新增行的 diff (排除删除行，避免修复安全问题的 commit 被误拦) ---
  DIFF_ADDED=$(echo "$DIFF" | grep -E '^\+[^+]' 2>/dev/null || echo "")

  # ============================================================
  # 1. 安全扫描 — 硬编码密钥/Token
  # ============================================================
  echo ""
  echo -e "${BLUE}--- 🔒 安全扫描 ---${NC}"

  # 1a. 高熵字符串检测 (仅扫描新增行，排除 git 哈希和 hex 字符串)
  if [[ -n "$DIFF_ADDED" ]]; then
    HIGH_ENTROPY=$(echo "$DIFF_ADDED" | grep -oE "[A-Za-z0-9+/=]{${ENTROPY_THRESHOLD:-40},}" 2>/dev/null | sort -u | head -20 || true)
    # 排除已知的非密钥模式
    if [[ -n "$HIGH_ENTROPY" ]]; then
      for ex_pattern in "${ENTROPY_EXCLUDE_PATTERNS[@]}"; do
        HIGH_ENTROPY=$(echo "$HIGH_ENTROPY" | grep -vE "$ex_pattern" 2>/dev/null || true)
      done
    fi
    if [[ -n "$HIGH_ENTROPY" ]]; then
      print_result "MEDIUM" "检测到高熵字符串（可能是密钥/Token）"
      echo "$HIGH_ENTROPY" | while read -r line; do echo "     $line"; done
      WARNINGS=$((WARNINGS + 1))
    fi
  fi

  # 1b. 已知密钥模式检测 (仅扫描新增行)
  if [[ -n "$DIFF_ADDED" ]]; then
    for entry in "${SECRET_PATTERNS[@]}"; do
      pattern="${entry%%:*}"
      rest="${entry#*:}"
      name="${rest%%:*}"
      level="${rest##*:}"

      # 跳过被项目配置忽略的模式
      if command -v should_ignore_pattern &>/dev/null && should_ignore_pattern "$name"; then
        continue
      fi

      MATCHES=$(echo "$DIFF_ADDED" | grep -oE -- "$pattern" 2>/dev/null | sort -u || true)
      if [[ -n "$MATCHES" ]]; then
        print_result "$level" "$name"
        echo "$MATCHES" | while read -r line; do echo "     $line"; done
        if [[ "$level" == "CRITICAL" ]]; then
          FAILED=$((FAILED + 1))
        else
          WARNINGS=$((WARNINGS + 1))
        fi
      fi
    done
  fi

  # 1c. .env 文件检测
  if echo "$DIFF_FILES" | grep -qE '(\.env$|\.env\.local$|\.env\.production$)' ; then
    print_result "CRITICAL" ".env 文件在改动中！可能泄露环境变量"
    FAILED=$((FAILED + 1))
  fi

  # ============================================================
  # 2. 隐私扫描 — PII 检测
  # ============================================================
  echo ""
  echo -e "${BLUE}--- 🛡️ 隐私扫描 ---${NC}"

  for entry in "${PII_PATTERNS[@]}"; do
    pattern="${entry%%:*}"
    rest="${entry#*:}"
    name="${rest%%:*}"
    level="${rest##*:}"

    if command -v should_ignore_pattern &>/dev/null && should_ignore_pattern "$name"; then
      continue
    fi

    MATCHES=$(echo "$DIFF_ADDED" | grep -oE -- "$pattern" 2>/dev/null | sort -u || true)

    # 特殊处理：邮箱 — 排除测试地址
    if [[ "$name" == "Email (non-test)" ]] && [[ -n "$MATCHES" ]]; then
      MATCHES=$(echo "$MATCHES" | grep -vE '(test@|example@|localhost|@test|@example|@localhost|your-?email)' 2>/dev/null || true)
    fi

    # 特殊处理：IP — 排除私有地址
    if [[ "$name" == "IP Address (non-private)" ]] && [[ -n "$MATCHES" ]]; then
      MATCHES=$(echo "$MATCHES" | grep -vE '(^127\.|^10\.|^192\.168\.|^172\.(1[6-9]|2[0-9]|3[01])\.|^0\.0\.0\.0|^169\.254\.|^22[4-9]\.|^23[0-9]\.)' 2>/dev/null || true)
    fi

    if [[ -n "$MATCHES" ]]; then
      COUNT=$(count_lines "$MATCHES")
      print_result "$level" "检测到 ${COUNT} 处 ${name}"
      echo "$MATCHES" | head -5 | while read -r line; do echo "     $line"; done
      if [[ "$level" == "CRITICAL" ]]; then
        FAILED=$((FAILED + 1))
      else
        WARNINGS=$((WARNINGS + 1))
      fi
    fi
  done

  # ============================================================
  # 3. 日志泄露检测
  # ============================================================
  echo ""
  echo -e "${BLUE}--- 📋 日志泄露检测 ---${NC}"

  for entry in "${LOG_LEAK_PATTERNS[@]}"; do
    pattern="${entry%%:*}"
    rest="${entry#*:}"
    name="${rest%%:*}"
    level="${rest##*:}"

    LOG_LEAKS=$(echo "$DIFF_ADDED" | grep -iE "$pattern" 2>/dev/null | head -10 || true)
    if [[ -n "$LOG_LEAKS" ]]; then
      print_result "$level" "日志中可能打印了敏感数据！($name)"
      echo "$LOG_LEAKS" | while read -r line; do echo "     $line"; done
      if [[ "$level" == "CRITICAL" ]]; then
        FAILED=$((FAILED + 1))
      else
        WARNINGS=$((WARNINGS + 1))
      fi
    else
      echo "  ✅ 未发现日志泄露"
    fi
  done

  # ============================================================
  # 4. 弱加密算法检测
  # ============================================================
  echo ""
  echo -e "${BLUE}--- 🔐 弱加密检测 ---${NC}"

  for entry in "${WEAK_CRYPTO_PATTERNS[@]}"; do
    pattern="${entry%%:*}"
    rest="${entry#*:}"
    name="${rest%%:*}"
    level="${rest##*:}"

    MATCHES=$(echo "$DIFF_ADDED" | grep -iE "$pattern" 2>/dev/null | head -10 || true)
    if [[ -n "$MATCHES" ]]; then
      print_result "$level" "检测到弱加密: $name"
      echo "$MATCHES" | while read -r line; do echo "     $line"; done
      if [[ "$level" == "CRITICAL" ]]; then
        FAILED=$((FAILED + 1))
      else
        WARNINGS=$((WARNINGS + 1))
      fi
    fi
  done

  # ============================================================
  # 5. 危险函数调用检测
  # ============================================================
  echo ""
  echo -e "${BLUE}--- ⚡ 危险函数调用检测 ---${NC}"

  for entry in "${DANGEROUS_EXEC_PATTERNS[@]}"; do
    pattern="${entry%%:*}"
    rest="${entry#*:}"
    name="${rest%%:*}"
    level="${rest##*:}"

    MATCHES=$(echo "$DIFF_ADDED" | grep -iE "$pattern" 2>/dev/null | head -10 || true)
    if [[ -n "$MATCHES" ]]; then
      print_result "$level" "检测到危险函数调用: $name"
      echo "$MATCHES" | while read -r line; do echo "     $line"; done
      if [[ "$level" == "CRITICAL" ]]; then
        FAILED=$((FAILED + 1))
      else
        WARNINGS=$((WARNINGS + 1))
      fi
    fi
  done

done

# ============================================================
# 结论
# ============================================================
echo ""
echo -e "${BLUE}============================================${NC}"

if [[ "$REVIEW_MODE" == "warn" ]]; then
  echo -e "${YELLOW}⚠️  REVIEW_MODE=warn — 审查完成，不阻止推送${NC}"
  echo -e "${YELLOW}   发现 ${FAILED} 个严重问题，${WARNINGS} 个警告${NC}"
  exit 0
fi

if [[ "$REVIEW_MODE" == "strict" ]] && [[ "$WARNINGS" -gt 0 ]]; then
  FAILED=$((FAILED + WARNINGS))
fi

if [[ "$FAILED" -gt 0 ]]; then
  echo -e "${RED}🛑 BLOCKED — 发现 ${FAILED} 个阻塞性问题，推送已阻止${NC}"
  echo ""
  echo "  修复以上问题后重新推送。"
  echo "  紧急情况可运行: SKIP_REVIEW=1 git push"
  exit 1
fi

echo -e "${GREEN}✅ CLEAR — 审查通过，允许推送${NC}"
[[ "$WARNINGS" -gt 0 ]] && echo -e "${YELLOW}   ${WARNINGS} 个非阻塞警告，建议推送后修复${NC}"
exit 0
